# Example .env for production - copy to .env and fill securely
# SECURITY
DEBUG=False
SECRET_KEY=please-change-this-to-a-long-random-secret

# Hosts (comma separated) e.g. example.com,www.example.com
ALLOWED_HOSTS=yourdomain.com

# CSRF trusted origins (comma separated, full urls) e.g. https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database (Postgres) - example format:
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Email / SMTP
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Security options
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1

# Optional: logging level
LOG_LEVEL=INFO
# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=school_management.settings

# Database - Development (SQLite)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# Database - Production (PostgreSQL)
# Uncomment for production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=school_management_db
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (Optional for production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Redis (For caching and celery)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
